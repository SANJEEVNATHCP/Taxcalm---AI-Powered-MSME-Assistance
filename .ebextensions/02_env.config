# Elastic Beanstalk Environment Variables Configuration
# Add your environment-specific variables here during deployment

option_settings:
  aws:elasticbeanstalk:application:environment:
    # Flask Configuration
    FLASK_APP: flask_app.py
    FLASK_ENV: production
    
    # Database Configuration (Update these with your RDS credentials)
    # DB_HOST: <your-rds-endpoint>.rds.amazonaws.com
    # DB_PORT: 5432
    # DB_NAME: gst_db
    # DB_USER: admin
    # DB_PASSWORD: <your-secure-password>
    
    # API Keys (Keep sensitive values in AWS Secrets Manager in production)
    # OPENROUTER_KEY_1: <your-openrouter-api-key>
    # ZOOM_CLIENT_ID: <your-zoom-client-id>
    # ZOOM_CLIENT_SECRET: <your-zoom-client-secret>
    # ZOOM_ACCOUNT_ID: <your-zoom-account-id>

  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 7
