# OpenRouter API Keys - Get your keys from https://openrouter.ai/keys
# IMPORTANT: Never commit real API keys to version control!
OPENROUTER_KEY_1=sk-or-v1-your-key-1-here
OPENROUTER_KEY_2=sk-or-v1-your-key-2-here
OPENROUTER_KEY_3=sk-or-v1-your-key-3-here
OPENROUTER_KEY_4=sk-or-v1-your-key-4-here
OPENROUTER_KEY_5=sk-or-v1-your-key-5-here

# FastAPI Configuration
DEBUG=false
PORT=8000
HOST=0.0.0.0

# Security Configuration
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
ENCRYPTION_KEY=your-32-byte-base64-encryption-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
SESSION_EXPIRY_HOURS=24
ENABLE_2FA=true

# Application Settings
APP_NAME=GST Stress-Reducer
APP_VERSION=2.0
# Zoom Meeting Scheduler Configuration
# Get credentials from: https://marketplace.zoom.us/develop/create
# App Type: Server-to-Server OAuth
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here
ZOOM_ACCOUNT_ID=your_account_id_here

# HuggingFace MCP Configuration
# Model Context Protocol integration for AI inference
HUGGINGFACE_MCP_ENDPOINT=http://localhost:3001
HUGGINGFACE_MCP_KEY=your-huggingface-mcp-api-key-here

# Strom MCP Configuration
# Model Context Protocol integration for file/data processing
STROM_MCP_ENDPOINT=http://localhost:3002
STROM_MCP_KEY=your-strom-mcp-api-key-here

# MCP General Settings
MCP_ENABLED=true
MCP_TIMEOUT=30